{
  "compilerOptions": {
    "target": "es2025",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
